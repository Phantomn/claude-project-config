{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(xxd:*)",
      "Bash(comm:*)",
      "Bash(python:*)",
      "Bash(find:*)",
      "Bash(python3:*)",
      "WebFetch(domain:github.com)",
      "mcp__ida-pro-mcp__check_connection",
      "mcp__ida-pro-mcp__get_metadata",
      "mcp__ida-pro-mcp__list_strings_filter",
      "mcp__serena__find_symbol",
      "mcp__tavily__tavily-search",
      "mcp__serena__list_dir",
      "Bash(xargs:*)",
      "mcp__serena__find_file",
      "mcp__serena__activate_project",
      "mcp__serena__search_for_pattern",
      "WebSearch",
      "mcp__ida-pro-mcp__list_funcs",
      "mcp__ida-pro-mcp__find_regex",
      "mcp__ida-pro-mcp__imports",
      "mcp__ida-pro-mcp__disasm",
      "mcp__ida-pro-mcp__find",
      "mcp__ida-pro-mcp__xrefs_to",
      "mcp__ida-pro-mcp__callees",
      "mcp__ida-pro-mcp__lookup_funcs",
      "Bash(rsync:*)",
      "mcp__ida-pro-mcp__decompile",
      "mcp__ida-pro-mcp__find_bytes",
      "mcp__ida-pro-mcp__get_bytes",
      "mcp__tavily__tavily-extract",
      "WebFetch(domain:cyber.wtf)",
      "WebFetch(domain:unit42.paloaltonetworks.com)",
      "mcp__ida-pro-mcp__get_int",
      "WebFetch(domain:www.perplexity.ai)",
      "mcp__ida-pro-mcp__search_structs",
      "mcp__ida-pro-mcp__get_string",
      "Bash(file:*)",
      "Bash(du:*)",
      "Bash(wc:*)",
      "mcp__ida-pro-mcp__py_eval",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(cmp:*)",
      "Bash(dd:*)",
      "mcp__ida-pro-mcp__list_globals",
      "mcp__ida-pro-mcp__read_struct",
      "mcp__ida-pro-mcp__get_global_value"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scripts/workflow-reminder.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/suggest-skill/scripts/suggest-skill.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "VAULT_DIR='/mnt/c/Users/tmdsv/Documents/Obsidian Vault' python3 .claude/skills/sync-claude-sessions/scripts/claude-sessions sync 2>/dev/null || true",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 .claude/skills/recall/scripts/extract-sessions.py --output ~/.claude/qmd-sessions --days 9999 && qmd update 2>/dev/null || true",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-rich.sh"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "team-assemble@team-attention-plugins": true
  },
  "model": "sonnet",
  "language": "Korean",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "생각하는 중",
      "분석하는 중",
      "처리하는 중",
      "검토하는 중",
      "탐색하는 중",
      "추론하는 중",
      "계획하는 중",
      "계산하는 중",
      "작업하는 중",
      "구상하는 중"
    ]
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "feedbackSurveyState": {
    "lastShownTime": 1754063128374
  },
  "effortLevel": "medium"
}
